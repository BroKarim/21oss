generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DATABASE_URL_UNPOOLED")
  extensions = [citext]
}

enum ReportType {
  BrokenLink
  WrongCategory
  WrongAlternative
  Outdated
  Other
}

enum PerkType {
  Developer
  Student
  Designer
  Creator
  Other
}



enum AdType {
  Banner
  ToolPage
  Button
  WidgetBanner
  SidebarBanner
  SidebarLink
  All
}

enum AnalyticsEventType {
  TOOL_CLICK
  AD_CLICK
}

enum ToolStatus {
  Draft
  Published
}


model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("user")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts Account[]
  sessions Session[]
  likes    Like[]
  reports  Report[]

  // Indexes
  @@index([id])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Ad {
  id             String   @id @default(cuid())
  email          String?
  name           String
  description    String?
  websiteUrl     String
  affiliateUrl   String?
  imageUrl       String?
  buttonLabel    String?
  faviconUrl     String?
  type           AdType   @default(All)
  startsAt       DateTime
  endsAt         DateTime
  subscriptionId String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  analyticsEvents AnalyticsEvent[]
}

enum ToolType {
  Tool        
  Template    
  Component  
  Asset      
}

enum TemplateType {
  Website
  Mobile
  Dashboard
}

model Tool {
    id              String    @id @default(cuid())
    name            String    @db.Citext
    slug            String    @unique
    websiteUrl      String?   @unique 
    repositoryUrl   String   @unique
    demoUrl         String?
    affiliateUrl    String?
    tagline         String?
    description     String?
    content         String?
    stars           Int       @default(0)
    forks           Int       @default(0)
    faviconUrl      String?
    screenshotUrl   String?
    screenshots     ToolScreenshot[]
    discountCode    String?
    discountAmount  String?
    firstCommitDate DateTime?
    lastCommitDate  DateTime?
    pageviews       Int?       @default(0)
    status          ToolStatus @default(Draft)
    publishedAt     DateTime?
    isTweeted       Boolean    @default(false)
    createdAt       DateTime  @default(now())
    updatedAt       DateTime  @updatedAt

    // Foreign Keys
    licenseId    String?
    inspiredById String?

    // Relations

    license    License?    @relation(fields: [licenseId], references: [id], onDelete: SetNull)
    stacks     Stack[]     @relation("ToolStacks")
    type        ToolType @default(Tool)
    /// Subtype khusus saat `type = Template`
    templateType TemplateType?
    likes      Like[]
    reports    Report[]
    analyticsEvents AnalyticsEvent[]

  // Indexes
  @@index([slug])
  @@index([licenseId])
  @@index([inspiredById])
  @@index([type, templateType])
}

model AnalyticsEvent {
  id        String             @id @default(cuid())
  type      AnalyticsEventType
  url       String

  // Optional references
  toolId    String?
  adId      String?

  // User origin metadata
  referrer  String?
  country   String?
  userAgent String?

  // Timestamp
  createdAt DateTime           @default(now())

  // Relations
  tool      Tool?              @relation(fields: [toolId], references: [id], onDelete: SetNull)
  ad        Ad?                @relation(fields: [adId], references: [id], onDelete: SetNull)

  // Indexes
  @@index([type])
  @@index([toolId])
  @@index([adId])
  @@index([createdAt])
  @@index([country])
}

model ToolScreenshot {
  id         String   @id @default(cuid())
  tool       Tool     @relation(fields: [toolId], references: [id])
  toolId     String

  imageUrl   String
  caption    String?   

  order      Int
}


model Stack {
  id          String    @id @default(cuid())
  name        String    @db.Citext
  slug        String    @unique
  description String?
  website     String?
  faviconUrl  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations  
  tools Tool[] @relation("ToolStacks")

  // Indexes
  @@index([slug])
}

model License {
  id        String   @id @default(cuid())
  name      String   @unique @db.Citext
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tools Tool[]

  // Indexes
  @@index([slug])
}

model DevPerk {
  id          String      @id @default(cuid())
  name        String      @db.Citext
  slug        String      @unique
  logoUrl     String?
  value       String?     
  description String?
  claimUrl    String?

  type        PerkType   
  tags        String[]    
  isFree      Boolean     @default(false)    
  isHot       Boolean     @default(false)
  isNew       Boolean     @default(false)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Index
  @@index([slug])
  @@index([type])
  @@index([isFree])
  @@index([isHot])
}


model ToolSubmission {
  id         String   @id @default(cuid())
  websiteUrl String
  githubUrl  String
  status     SubmissionStatus @default(Pending)
  createdAt  DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

enum SubmissionStatus {
  Pending
  Approved
  Rejected
}

model Session {
  id             String   @id @default(cuid())
  token          String   @unique
  expiresAt      DateTime
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  // Indexes
  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  // Indexes
  @@index([userId])
}


model Report {
  id        String     @id @default(cuid())
  type      ReportType
  message   String?
  userId    String?
  toolId    String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  tool    Tool?    @relation(fields: [toolId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([toolId])
  @@index([userId])
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  toolId    String
  createdAt DateTime @default(now())

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool    Tool    @relation(fields: [toolId], references: [id], onDelete: Cascade)

  // Indexes
  @@unique([userId, toolId])
  @@index([userId])
  @@index([toolId])
}
